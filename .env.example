# Client defaults
TUNNEL_SERVER_URL=ws://127.0.0.1:8080/_tunnel_connect
TUNNEL_API_URL=http://127.0.0.1:8080
# Optional: leave empty for auto-generated subdomain on each start
TUNNEL_SUBDOMAIN=
TUNNEL_LOCAL_URL=http://127.0.0.1:3000
TUNNEL_AUTH_TOKEN=
TUNNEL_USERNAME=
TUNNEL_PASSWORD=
TUNNEL_REVOKE_TOKEN=
TUNNEL_SESSION_FILE=

# Server defaults
PORT=8080
DOMAIN=example.com
DB_PATH=./data/tunnel.db
REQUEST_TIMEOUT_MS=30000
# Optional bootstrap admin user (created/promoted at startup)
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
