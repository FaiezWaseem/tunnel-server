{
  "name": "tunnel-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun run server/server.ts",
    "dev:client": "bun run client/client.ts",
    "build:client:win": "bun build ./client/client.ts --compile --target=bun-windows-x64 --outfile ./dist/tunnel-client.exe",
    "build:client:linux": "bun build ./client/client.ts --compile --target=bun-linux-x64 --outfile ./dist/tunnel-client",
    "build:client:mac": "bun build ./client/client.ts --compile --target=bun-darwin-arm64 --outfile ./dist/tunnel-client-mac"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  }
}
